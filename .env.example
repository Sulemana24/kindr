SECRET_KEY=replace-with-long-random-string

# Database: omit for SQLite, or set PostgreSQL (Docker Compose sets this for the `web` service)
# DATABASE_URL=postgresql://kindr:kindr@localhost:5432/kindr
# DATABASE_URL=postgresql://user:pass@host:5432/kindr
DATABASE_URL=postgresql://kindr:kindr@localhost:5432/kindr

# Session cookies (Flask login uses the session cookie)
# Local HTTP: leave unset or false. Production HTTPS: set true
# SESSION_COOKIE_SECURE=true
# Optional: Lax (default), Strict, or None (requires Secure in browsers)
# SESSION_COOKIE_SAMESITE=Lax

# Email OTP (optional in dev — codes are printed to the console if unset)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER="Kindr <no-reply@example.com>"
MAIL_USE_TLS=true

# Africa's Talking SMS (optional; E.164 phone on signup/login)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=

# Google OAuth — redirect URI: http://127.0.0.1:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook — redirect: http://127.0.0.1:5000/auth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple Sign In — callback: https://your-domain/auth/apple/callback (HTTPS in production)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Admin setup (choose ONE approach):
# 1) Dedicated single admin account (recommended)
# ADMIN_LOGIN_EMAIL=admin@example.com
# ADMIN_LOGIN_PASSWORD=change-this-admin-password
# ADMIN_LOGIN_NAME=Platform Admin
#
# 2) Multiple existing user accounts as admins (legacy)
# ADMIN_EMAILS=admin@example.com

# Official support inbox (AI escalations + optional contact). Default: bekindrgh@gmail.com
# SUPPORT_EMAIL=bekindrgh@gmail.com

# Google Gemini (About-page AI assistant) — https://aistudio.google.com/apikey
# In Google Cloud Console: enable "Generative Language API" for the key’s project.
# API key restrictions: use "None" or IP/server restrictions — not "HTTP referrers" (server has no referrer).
# Optional model; server tries fallbacks if a name 404s.
# GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Paystack (GHS) — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
# Exact URL Paystack opens after payment (must match what you register in Paystack dashboard).
# Local dev: http://127.0.0.1:5000/paystack/callback
PAYSTACK_CALLBACK_URL=http://127.0.0.1:5000/paystack/callback
